      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2"><di:waypoint x="350" y="340"/><di:waypoint x="390" y="340"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3"><di:waypoint x="426" y="340"/><di:waypoint x="450" y="340"/><di:waypoint x="450" y="150"/><di:waypoint x="480" y="150"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4"><di:waypoint x="660" y="150"/><di:waypoint x="720" y="150"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5"><di:waypoint x="770" y="150"/><di:waypoint x="795" y="150"/><di:waypoint x="795" y="108"/><di:waypoint x="820" y="108"/><bpmndi:BPMNLabel><dc:Bounds x="780" y="118" width="18" height="14"/></bpmndi:BPMNLabel></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6"><di:waypoint x="770" y="150"/><di:waypoint x="795" y="150"/><di:waypoint x="795" y="340"/><di:waypoint x="820" y="340"/><bpmndi:BPMNLabel><dc:Bounds x="778" y="244" width="28" height="14"/></bpmndi:BPMNLabel></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7"><di:waypoint x="856" y="108"/><di:waypoint x="900" y="108"/></bpmndi:BPMNEdge>
